# =============================================================================
# Convexity Desk — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# All variables without NEXT_PUBLIC_ prefix are server-side only.
# =============================================================================

# -----------------------------------------------------------------------------
# App Configuration
# -----------------------------------------------------------------------------

# App mode: demo | mixed | live
# demo: uses all static demo data, no API keys required
# mixed: attempts live APIs, falls back to demo data on failure
# live: requires all API keys, errors on failure
NEXT_PUBLIC_APP_MODE=demo

# Public URL (used for metadata and OG tags)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# App name (optional override)
NEXT_PUBLIC_APP_NAME=Convexity Desk

# -----------------------------------------------------------------------------
# SoSoValue Integration
# See: https://openapi.sosovalue.com
# -----------------------------------------------------------------------------

# Primary API key for SoSoValue OpenAPI
SOSOVALUE_API_KEY=

# Base URL for SoSoValue API
SOSOVALUE_BASE_URL=https://openapi.sosovalue.com

# Optional: Legacy client credentials if required
SOSOVALUE_CLIENT_ID=
SOSOVALUE_CLIENT_SECRET=
SOSOVALUE_LEGACY_BASE_URL=

# -----------------------------------------------------------------------------
# SoDEX Integration
# -----------------------------------------------------------------------------

# SoDEX public API base URL (mainnet)
SODEX_BASE_URL=

# SoDEX testnet API base URL (for Wave 3 execution)
SODEX_TESTNET_BASE_URL=

# SoDEX API key (if required for authenticated endpoints)
SODEX_API_KEY=

# SoDEX private key for testnet order signing (Wave 3 only)
# NEVER expose this on the client side
SODEX_PRIVATE_KEY=

# SoDEX account ID for testnet execution (Wave 3)
SODEX_ACCOUNT_ID=

# -----------------------------------------------------------------------------
# Persistence (Wave 3)
# -----------------------------------------------------------------------------

# Supabase URL and anon key (Wave 3 persistence layer)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key (server-side only — never expose to client)
SUPABASE_SERVICE_ROLE_KEY=

# SQLite database path (alternative to Supabase for Wave 3)
# SQLITE_DB_PATH=./data/convexity.db

# -----------------------------------------------------------------------------
# Wallet Integration (Wave 3)
# -----------------------------------------------------------------------------

# WalletConnect project ID (for wagmi/ConnectKit/RainbowKit)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Chain ID for primary network (e.g., 1 for Ethereum mainnet)
NEXT_PUBLIC_CHAIN_ID=1

# -----------------------------------------------------------------------------
# Smart Contracts (Wave 3)
# -----------------------------------------------------------------------------

# Contract addresses (deployed on testnet for Wave 3 demo)
NEXT_PUBLIC_HEDGE_RECEIPT_LOGGER_ADDRESS=
NEXT_PUBLIC_RISK_POLICY_REGISTRY_ADDRESS=
NEXT_PUBLIC_OUTCOME_LEDGER_ANCHOR_ADDRESS=

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------

# Enable live SoSoValue integration (requires SOSOVALUE_API_KEY)
ENABLE_SOSOVALUE_LIVE=false

# Enable live SoDEX market data (requires SODEX_BASE_URL)
ENABLE_SODEX_LIVE=false

# Enable testnet execution (requires SODEX_TESTNET_BASE_URL, Wave 3)
ENABLE_TESTNET_EXECUTION=false

# Enable smart contract logging (Wave 3)
ENABLE_CONTRACT_LOGGING=false

# -----------------------------------------------------------------------------
# Development / Debug
# -----------------------------------------------------------------------------

# Log level: error | warn | info | debug
LOG_LEVEL=info

# Show API adapter debug output in server logs
DEBUG_ADAPTERS=false
